doctype html
html(lang="ja")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body{
        margin:0;
        min-height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        overflow:hidden;

        background:
          radial-gradient(
            circle at top,
            rgba(110,160,170,0.20),
            transparent 45%
          ),
          linear-gradient(
            180deg,
            #0b1620 0%,
            #12232c 45%,
            #081218 100%
          );

        font-family:serif;
        color:#E8EEF5;
      }

      /* 月明かり */
      .moon{
        position:absolute;
        top:80px;
        right:120px;

        width:140px;
        height:140px;
        border-radius:50%;

        background:
          radial-gradient(
            circle,
            rgba(235,245,255,0.95),
            rgba(190,215,230,0.70)
          );

        box-shadow:
          0 0 35px rgba(200,230,255,0.55),
          0 0 90px rgba(200,230,255,0.20);
      }

      /* 霧 */
      .mist{
        position:absolute;
        inset:0;

        background:
          radial-gradient(
            ellipse at bottom,
            rgba(180,220,230,0.10),
            transparent 70%
          );

        pointer-events:none;
      }

      .night-card{
        position:relative;
        z-index:5;

        max-width:620px;

        background:
          rgba(15,25,30,0.45);

        backdrop-filter:blur(12px);

        border:
          1px solid rgba(220,240,255,0.16);

        border-radius:28px;

        box-shadow:
          0 10px 40px rgba(0,0,0,0.45);

        color:#E8EEF5;
      }

      .title404{
        font-size:5rem;
        letter-spacing:0.15em;
        color:#D6E6F8;
      }

      .subtitle{
        color:#C8D4DD;
        line-height:2;
      }

      .diary-btn{
        background:#4E6873;
        border:none;
        color:white;
        transition:0.3s;
      }

      .diary-btn:hover{
        background:#6C8894;
        color:white;
        transform:translateY(-2px);
      }

  body

    .moon
    .mist

    .card.night-card.p-5.text-center

      h1.title404.mb-4
        | 404 NotFound

      h2.mb-4
        | 夜に迷い込んでしまいました

      p.subtitle.mb-5
        | 探していたページは、
        br
        | 月明かりの奥へ隠れてしまったようです。

      a.btn.diary-btn.btn-lg(href="/posts")
        | 日記へ帰る