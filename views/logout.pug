doctype html
html(lang="ja")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body{
        background:linear-gradient(135deg,#1F2937,#374151,#4B5563);
        min-height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        font-family: serif;
      }

      .diary-card{
        background:rgba(255,255,255,0.08);
        border:1px solid rgba(255,255,255,0.15);
        border-radius:24px;
        box-shadow:0 8px 32px rgba(0,0,0,0.35);
        backdrop-filter: blur(10px);
        color:#F3F4F6;
        max-width:520px;
      }

      .diary-title{
        font-size:2.2rem;
        letter-spacing:0.15em;
        color:#E5E7EB;
      }

      .diary-btn{
        background:#5B6C8F;
        color:white;
        border:none;
        transition:0.3s;
      }

      .diary-btn:hover{
        background:#7488B2;
        color:white;
      }

  body

    .card.diary-card.p-5.text-center

      .mb-4(style="font-size:3rem;")
        | 📔

      h1.diary-title.mb-4
        | いってらっしゃい

      a.btn.diary-btn.btn-lg(href="/posts")
        | 日記を開く