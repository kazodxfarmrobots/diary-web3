doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css")
    link(rel="stylesheet" href="style.css")
    // フォント
    link(
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap"
      rel="stylesheet")
    title Diary
  body.container.overflow-scroll
    nav.navbar.fixed-top(style="background-color:#8B5E3C;")
      div.container-fluid
        h1.text-light.navbar-brand.mx-auto Diary
          i.bi-book-fill.ms-1
        div.dropdown
          button.btn.btn-outline-light.dropdown-toggle(type="button" id="menu" data-bs-toggle="dropdown" aria-expanded="false") #{user}
            i.bi-gear-fill.ms-1
          ul.dropdown-menu.dropdown-menu-end(aria-labelledby="menu")
            li
              a.dropdown-item(href="/logout") Diaryを閉じる
    each post in posts
      - const cardClass = 'card my-3'
      - const isDeletable = (user === post.postedBy || user === 'admin')
      if isDeletable
        div(class=cardClass)
          div.card-body
            div.d-flex.justify-content-between
              h5.card-title #{post.postedBy}
              - const tooltipTitle = `<small>${post.relativeCreatedAt}</small>`
              small.card-text.float-end(data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" title=tooltipTitle) #{post.absoluteCreatedAt}
            p.card-text.lead #{post.content}
          div.card-footer.d-flex.justify-content-end
            form(method="post" action="/posts/delete")
              input(type="hidden" name="id" value=post.id)
              button(type="submit").btn.btn-outline-danger.btn-sm
                i.bi-trash
    div.fixed-bottom.p-4.bg-body
      form(method="post" action="/posts" name="message-form").container-fluid.row.g-3
        div.col-12
          textarea(name="content" rows="4" placeholder="Ctrl(Command)+Enterで日記をつけられます").form-control
          input(type="hidden" name="oneTimeToken" value=oneTimeToken)
        div.col-12
          button(type="submit").btn.btn-primary.float-end
            i.bi-pencil

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha256-qlPVgvl+tZTCpcxYJFdHB/m6mDe84wRr+l81VoYPTgQ="
      crossorigin="anonymous")
    script(src="diary-web3.js")